{
	"name": "alleviate",
	"type": "module",
	"version": "0.0.0-alpha.1",
	"author": "BeeeQueue <adam@haglund.dev>",
	"license": "MIT",
	"packageManager": "pnpm@11.6.0",
	"engines": {
		"node": "^22 || ^24 || ^26 || ^27"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": "./dist/index.mjs",
		"./cache/lru": "./dist/cache/lru.mjs",
		"./package.json": "./package.json"
	},
	"lint-staged": {
		"*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,json5,yaml,yml,css,scss,md}": [
			"oxfmt --no-error-on-unmatched-pattern"
		]
	},
	"simple-git-hooks": {
		"pre-commit": "./node_modules/.bin/lint-staged"
	},
	"scripts": {
		"build": "tsdown",
		"lint": "eslint --flag unstable_native_nodejs_ts_config",
		"lint:format": "oxfmt --check",
		"test": "vitest",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@changesets/changelog-github": "1.0.0-next.5",
		"@changesets/cli": "3.0.0-next.5",
		"@e18e/eslint-plugin": "0.5.0",
		"@tsconfig/node26": "26.0.0",
		"@tsconfig/strictest": "2.0.8",
		"@types/node": "25.9.2",
		"@typescript/native-preview": "7.0.0-dev.20260611.2",
		"lint-staged": "17.0.7",
		"oxfmt": "0.54.0",
		"oxlint": "1.69.0",
		"oxlint-tsgolint": "0.23.0",
		"p-queue": "9.3.0",
		"simple-git-hooks": "2.13.1",
		"tsdown": "0.22.2",
		"typescript": "6.0.3",
		"vitest": "5.0.0-beta.5"
	}
}
