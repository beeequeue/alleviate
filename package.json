{
	"name": "alleviate",
	"type": "module",
	"version": "0.1.0",
	"author": "BeeeQueue <adam@haglund.dev>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/beeequeue/alleviate.git"
	},
	"packageManager": "pnpm@11.9.0",
	"engines": {
		"node": "^22.11 || ^24 || ^26 || ^27"
	},
	"files": [
		"dist",
		"src/**/LICENSE*"
	],
	"exports": {
		".": "./dist/index.mjs",
		"./cache/lru": "./dist/cache/lru.mjs",
		"./cache/memoize": "./dist/cache/memoize.mjs",
		"./cache/ttl-map": "./dist/cache/ttl-map.mjs",
		"./promise/limiter": "./dist/promise/limiter.mjs",
		"./promise/queue": "./dist/promise/queue.mjs",
		"./package.json": "./package.json"
	},
	"lint-staged": {
		"*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,json5,yaml,yml,css,scss,md}": [
			"oxfmt --no-error-on-unmatched-pattern"
		]
	},
	"simple-git-hooks": {
		"pre-commit": "./node_modules/.bin/lint-staged"
	},
	"scripts": {
		"build": "tsdown",
		"lint": "oxlint",
		"lint:format": "oxfmt --check",
		"prepack": "node scripts/clean-before-pack.ts",
		"test": "vitest"
	},
	"devDependencies": {
		"@changesets/changelog-github": "https://pkg.pr.new/changesets/changesets/@changesets/changelog-github@a69ede9",
		"@changesets/cli": "https://pkg.pr.new/changesets/changesets/@changesets/cli@a69ede9",
		"@e18e/eslint-plugin": "0.5.0",
		"@tsconfig/node26": "26.0.0",
		"@tsconfig/strictest": "2.0.8",
		"@types/node": "25.9.3",
		"@typescript/native-preview": "7.0.0-dev.20260614.1",
		"lint-staged": "17.0.7",
		"object-identity": "0.2.0",
		"oxfmt": "0.54.0",
		"oxlint": "1.69.0",
		"oxlint-tsgolint": "0.23.0",
		"p-queue": "9.3.0",
		"publint": "0.3.21",
		"simple-git-hooks": "2.13.1",
		"tsdown": "0.22.2",
		"vitest": "5.0.0-beta.5"
	},
	"inlinedDependencies": {
		"object-identity": "0.2.0"
	}
}
