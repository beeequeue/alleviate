{
	"name": "alleviate",
	"description": "A collection of tiny caching and promise utilities",
	"keywords": [
		"cache",
		"promise",
		"queue",
		"limiter",
		"memoize",
		"lru",
		"ttl",
		"dataloader"
	],
	"author": "BeeeQueue <adam@haglund.dev>",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/beeequeue/alleviate.git"
	},
	"version": "0.2.1",
	"type": "module",
	"packageManager": "pnpm@11.13.1",
	"engines": {
		"node": "^22.11 || ^24 || ^26 || ^27"
	},
	"files": [
		"dist",
		"src/**/LICENSE*"
	],
	"exports": {
		".": "./dist/index.mjs",
		"./cache/dataloader": "./dist/cache/dataloader.mjs",
		"./cache/lru": "./dist/cache/lru.mjs",
		"./cache/memoize": "./dist/cache/memoize.mjs",
		"./cache/ttl-map": "./dist/cache/ttl-map.mjs",
		"./promise/limiter": "./dist/promise/limiter.mjs",
		"./promise/queue": "./dist/promise/queue.mjs",
		"./package.json": "./package.json"
	},
	"lint-staged": {
		"*.{js,jsx,mjs,cjs,ts,tsx,mts,cts,json,json5,yaml,yml,css,scss,md}": [
			"oxfmt --no-error-on-unmatched-pattern"
		]
	},
	"simple-git-hooks": {
		"pre-commit": "./node_modules/.bin/lint-staged"
	},
	"scripts": {
		"build": "tsdown",
		"lint": "oxlint",
		"lint:format": "oxfmt --check",
		"prepack": "node scripts/clean-before-pack.ts",
		"test": "vitest"
	},
	"devDependencies": {
		"@changesets/changelog-github": "1.0.0-next.7",
		"@changesets/cli": "3.0.0-next.9",
		"@e18e/eslint-plugin": "0.5.1",
		"@tsconfig/node26": "26.0.0",
		"@tsconfig/strictest": "2.0.8",
		"@types/node": "26.1.1",
		"lint-staged": "17.0.8",
		"object-identity": "0.2.3",
		"oxfmt": "0.59.0",
		"oxlint": "1.74.0",
		"oxlint-tsgolint": "0.25.0",
		"publint": "0.3.21",
		"simple-git-hooks": "2.13.1",
		"tsdown": "0.22.9",
		"typescript": "7.0.2",
		"vitest": "5.0.0-beta.6"
	},
	"inlinedDependencies": {
		"object-identity": "0.2.3"
	}
}
